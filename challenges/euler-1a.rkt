;;;---------------------------------------------------------------------------------------------------
;;; Project Euler 1: Multiples of 3 or 5 (Approach A)
;;;---------------------------------------------------------------------------------------------------

#lang racket/base

(require "../lib/base.rkt")

(provide test solve)


;;;---------------------------------------------------------------------------------------------------
;;; Solution
;;;---------------------------------------------------------------------------------------------------

(define (euler ns bound)
  (let loop ((m 1) (acc 0))
    (if (< m bound)
        (loop (add1 m) (if (multiple-of-any? m ns) (+ acc m) acc))
        acc)))


;;;---------------------------------------------------------------------------------------------------
;;; Runme interface
;;;---------------------------------------------------------------------------------------------------

(define (test) (= 23 (euler '(3 5) 10)))
(define (solve) (euler '(3 5) 1000))
