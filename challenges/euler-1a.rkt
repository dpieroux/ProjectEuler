;;;---------------------------------------------------------------------------------------------------
;;; Project Euler 1 (Approach A)
;;;---------------------------------------------------------------------------------------------------

#lang racket/base

(require "../lib/base.rkt")

(provide euler-1a test solve)

;;;---------------------------------------------------------------------------------------------------
;;; Algorithm
;;;---------------------------------------------------------------------------------------------------

(define (euler-1a ns bound)
  (let loop ((m 1) (acc 0))
    (if (< m bound)
        (loop (add1 m) (if (multiple-of-any? m ns) (+ acc m) acc))
        acc)))

;;;---------------------------------------------------------------------------------------------------
;;; Runme interface
;;;---------------------------------------------------------------------------------------------------

(define (test) (= 23 (euler-1a '(3 5) 10)))
(define (solve) (euler-1a '(3 5) 1000))
